# Application
APP_NAME="KadrGo"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE="Asia/Tashkent"
APP_URL=http://localhost:8000

APP_LOCALE=uz
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=uz_UZ

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kadrgo
DB_USERNAME=root
DB_PASSWORD=

# Session & Cache
# Local: database | Production: redis
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Local: database | Production: redis
CACHE_STORE=database
CACHE_PREFIX=kadrgo

# Queue
# Local: database | Production: redis
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log

# Nutgram cache
# Local: file | Production: redis
NUTGRAM_CACHE=file

# Redis (required for production)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# File Storage
FILESYSTEM_DISK=local
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=

# Mail
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@kadrgo.uz"
MAIL_FROM_NAME="${APP_NAME}"

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=kadrgobot
TELEGRAM_CHANNEL_USERNAME=kadrgo_uz
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL="${APP_URL}/api/webhook/telegram/${TELEGRAM_WEBHOOK_SECRET}"

# Telegram Mini App
TELEGRAM_MINI_APP_URL="${APP_URL}/miniapp"

# Payment Gateways
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
PAYME_TEST_KEY=
PAYME_ENDPOINT=https://checkout.paycom.uz

CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
CLICK_MERCHANT_USER_ID=

UZUM_MERCHANT_ID=
UZUM_SECRET_KEY=
UZUM_ENDPOINT=https://api.uzum.uz

# SMS Service (Eskiz.uz - for OTP)
SMS_ESKIZ_EMAIL=
SMS_ESKIZ_PASSWORD=
SMS_FROM=4546

# AI Service (Claude/DeepSeek)
AI_SERVICE=claude
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Maps
YANDEX_MAPS_API_KEY=

# Admin Panel
ADMIN_EMAIL=admin@kadrgo.uz
ADMIN_PASSWORD=

# Rate Limiting
RATE_LIMIT_API=60
RATE_LIMIT_AUTH=10
RATE_LIMIT_SEARCH=120
RATE_LIMIT_VACANCY_CREATE=5
RATE_LIMIT_APPLICATION_SUBMIT=10
RATE_LIMIT_PAYMENT=10

# SEO & Analytics
GOOGLE_SITE_VERIFICATION=
YANDEX_SITE_VERIFICATION=
GOOGLE_ANALYTICS_ID=
META_PIXEL_ID=

# Monitoring (optional)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0

# Horizon (optional - for production)
HORIZON_PREFIX=kadrgo
HORIZON_BALANCE=simple

# Development
VITE_APP_NAME="${APP_NAME}"

# ============================================================
# KADRGO — PRODUCTION MUHIT SOZLAMALARI
# Bu faylni .env ga nusxalang va barcha qiymatlarni to'ldiring
# ============================================================

# Application
APP_NAME="KadrGo"
APP_ENV=production
APP_KEY=                          # php artisan key:generate
APP_DEBUG=false                   # MUHIM: false bo'lishi shart!
APP_TIMEZONE="Asia/Tashkent"
APP_URL=https://kadrgo.uz         # Haqiqiy domen

APP_LOCALE=uz
APP_FALLBACK_LOCALE=ru

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# Logging — production sozlamalari
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning                 # debug emas, warning!
LOG_DAILY_DAYS=14

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kadrgo
DB_USERNAME=kadrgo_user           # root EMAS!
DB_PASSWORD=                      # Kuchli parol qo'ying

# Session & Cache — REDIS ishlatish shart
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.kadrgo.uz

CACHE_STORE=redis
CACHE_PREFIX=kadrgo

# Queue — REDIS
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log

# Nutgram cache — REDIS (bot conversationlar uchun muhim!)
NUTGRAM_CACHE=redis

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=                   # Kuchli parol qo'ying
REDIS_PORT=6379

# File Storage
FILESYSTEM_DISK=public

# Mail
MAIL_MAILER=smtp
MAIL_HOST=                        # SMTP server
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@kadrgo.uz"
MAIL_FROM_NAME="${APP_NAME}"

# Telegram Bot
TELEGRAM_BOT_TOKEN=               # YANGI token yarating!
TELEGRAM_BOT_USERNAME=kadrgobot
TELEGRAM_CHANNEL_USERNAME=kadrgo_uz
TELEGRAM_WEBHOOK_URL="${APP_URL}/api/webhook/telegram"

# Telegram Mini App
TELEGRAM_MINI_APP_URL="${APP_URL}/miniapp"

# Payment Gateways
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=

CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
CLICK_MERCHANT_USER_ID=

UZUM_MERCHANT_ID=
UZUM_SECRET_KEY=
UZUM_ENDPOINT=https://api.uzum.uz

# AI Service
AI_SERVICE=claude
ANTHROPIC_API_KEY=                # YANGI kalit yarating!

# Admin Panel
ADMIN_EMAIL=admin@kadrgo.uz
ADMIN_PASSWORD=                   # Kuchli parol!

# Sanctum
SANCTUM_STATEFUL_DOMAINS=kadrgo.uz,www.kadrgo.uz
SANCTUM_TOKEN_EXPIRATION=43200

# Monitoring
SENTRY_LARAVEL_DSN=               # Sentry DSN (tavsiya etiladi)
SENTRY_TRACES_SAMPLE_RATE=0.1

# Horizon
HORIZON_PREFIX=kadrgo
HORIZON_BALANCE=simple

VITE_APP_NAME="${APP_NAME}"
